{
  "name": "bizsuite",
  "version": "2.0.0",
  "description": "BizSuite — Invoice & Tender Manager for Indian SMEs",
  "main": "main.js",
  "author": {
    "name": "BizSuite",
    "email": "admin@bizsuite.app"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.bizsuite.app",
    "productName": "BizSuite",
    "copyright": "Copyright 2026",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BizSuite",
      "runAfterFinish": true
    }
  }
}
